@page
@model EstudiantesHTMLModel
@{
    ViewData["Title"] = "Estudiantes";
}
<center>
    <div class="container">
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div align="left"><h3>Gestión de Estudiantes</h3></div>
            
            <div class="mb-3">
                <input type="submit" value="Refrescar" class="btn btn-secondary" asp-page-handler="BtRefrescar" />
                <input type="submit" value="Nuevo" class="btn btn-secondary" asp-page-handler="BtNuevo" disabled="@(Model.Estudiante != null)" />
                <input type="submit" value="Guardar" class="btn btn-primary" asp-page-handler="BtGuardar" disabled="@(Model.Estudiante == null)" />
            </div>

            @if (Model.Estudiante != null)
            {
                <input type="hidden" asp-for="Estudiante!.Id" />
            
                <div class="card p-4 shadow-sm" style="max-width: 600px;">
                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label" style="text-align: left;">ID Estudiante</label>
                        <div class="col-sm-8">
                            <input class="form-control" value="@Model.Estudiante.Id" readonly style="background-color: #e9ecef;" />
                        </div>
                    </div>

                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label" style="text-align: left;">Nombre</label>
                        <div class="col-sm-8">
                            <input class="form-control" asp-for="Estudiante!.Nombre" />
                        </div>
                    </div>

                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label" style="text-align: left;">Teléfono de Contacto</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control" asp-for="Estudiante!.Contacto" />
                        </div>
                    </div>

                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label" style="text-align: left;">Perfil</label>
                        <div class="col-sm-8">
                            <select asp-for="Estudiante!.Perfil" class="form-control">
                                <option value="Desplazado">Desplazado (40%)</option>
                                <option value="Votante">Votante (15%)</option>
                                <option value="Reingreso">Reingreso (10%)</option>
                                <option value="Ninguno">Ninguno</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label" style="text-align: left;">Estado Activo</label>
                        <div class="col-sm-8" style="text-align: left;">
                            <input type="checkbox" asp-for="Estudiante!.Activo" />
                        </div>
                    </div>
                </div>
            }

            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml")
            }

            @if (Model.Estudiante != null && Model.Borrando)
            {
                <div class='popup' style="background: rgba(0,0,0,0.5); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1000;">
                    <div class='pp_ms_inner' style="background: white; margin: 15% auto; padding: 20px; width: 40%; border-radius: 8px;">
                        <h2 align="left">Confirmación</h2>
                        <h6 align="left">¿Desea borrar al estudiante <strong>@Model.Estudiante!.Nombre</strong>?</h6>
                        <div class="mt-3">
                            <input type="submit" value="Cancelar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                            <input type="submit" value="Confirmar Borrado" asp-page-handler="BtBorrar" class="btn btn-danger" />
                        </div>
                    </div>
                </div>
            }

            @if (Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="table table-striped table-bordered table-hover mt-4">
                    <thead class="thead-dark">
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Contacto</th>
                            <th>Perfil</th>
                            <th>Activo</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var elemento in Model.Lista)
                        {
                            <tr>
                                <td>@elemento.Id</td>
                                <td>@elemento.Nombre</td>
                                <td>@elemento.Contacto</td>
                                <td>@elemento.Perfil</td>
                                <td>@(elemento.Activo ? "Sí" : "No")</td>
                                <td>
                                    <input type="submit" value="Editar" asp-page-handler="BtModificar" class="btn btn-warning btn-sm" asp-route-data="@elemento.Id" />
                                    <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-danger btn-sm" asp-route-data="@elemento.Id" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </form>
    </div>
</center>