@page
@model MatriculasHTMLModel
@{
    ViewData["Title"] = "Matriculas";
}
<center>
    <div class="container">
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div align="left"><h3>Gestión de Matrículas</h3></div>
            <div class="mb-3">
                <input type="submit" value="Refrescar" class="btn btn-secondary" asp-page-handler="BtRefrescar" />
                <input type="submit" value="Nuevo" class="btn btn-secondary" asp-page-handler="BtNuevo" disabled="@(Model.Matricula != null)" />
                <input type="submit" value="Guardar" class="btn btn-primary" asp-page-handler="BtGuardar" disabled="@(Model.Matricula == null)" />
            </div>

            @if (Model.Matricula != null)
            {
                var mat = Model.Matricula;
                <input type="hidden" name="Matricula.Id" value="@mat.Id" />
                <div class="card p-4 shadow-sm" style="max-width: 600px;">
                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label">Nombre Salón</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control" name="Matricula.Nombre" value="@mat.Nombre" />
                        </div>
                    </div>
                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label">Costo Base</label>
                        <div class="col-sm-8">
                            <input type="number" class="form-control" name="Matricula.Costo" value="@mat.Costo" />
                        </div>
                    </div>
                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label">Fecha de Ingreso</label>
                        <div class="col-sm-8">
                            <input type="date" class="form-control" name="Matricula.FechaIngreso" value="@mat.FechaIngreso.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label">Tipo de Descuento</label>
                        <div class="col-sm-8">
                            <select class="form-control" asp-for="Matricula.TipoDescuento">
                                <option value="Desplazado">Desplazado (40%)</option>
                                <option value="Votante">Votante (15%)</option>
                                <option value="Reingreso">Reingreso (10%)</option>
                                <option value="Ninguno">Ninguno</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row mb-2">
                        <label class="col-sm-4 col-form-label">Id Estudiante</label>
                        <div class="col-sm-8">
                            <input type="number" class="form-control" name="Matricula.Estudiantes" value="@mat.Estudiantes" />
                        </div>
                    </div>
                </div>
            }

            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml");
            }

            @if (Model.Matricula != null && Model.Borrando)
            {
                <div class='popup' style="background: rgba(0,0,0,0.5); position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1000;">
                    <div class='pp_ms_inner' style="background: white; margin: 15% auto; padding: 20px; width: 40%; border-radius: 8px;">
                        <h2 align="left">Confirmación</h2>
                        <h6 align="left">¿Desea borrar la matrícula <strong>@Model.Matricula!.Nombre</strong>?</h6>
                        <div class="mt-3">
                            <input type="submit" value="Cancelar" asp-page-handler="BtCerrar" class="btn btn-secondary" />
                            <input type="submit" value="Confirmar Borrado" asp-page-handler="BtBorrar" class="btn btn-danger" />
                        </div>
                    </div>
                </div>
            }

            @if (Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="table table-striped table-bordered table-hover mt-4">
                    <thead class="thead-dark">
                        <tr>
                            <th>Nombre Salón</th>
                            <th>Costo Final</th>
                            <th>Fecha Ingreso</th>
                            <th>Tipo Descuento</th>
                            <th>Estudiante</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var elemento in Model.Lista)
                        {
                            <tr>
                                <td>@elemento.Nombre</td>
                                <td>@elemento.Costo.ToString("C")</td>
                                <td>@elemento.FechaIngreso.ToShortDateString()</td>
                                <td>@elemento.TipoDescuento</td>
                                <td>@(elemento._Estudiante?.Nombre ?? elemento.Estudiantes?.ToString())</td>
                                <td>
                                    <input type="submit" value="Modificar" asp-page-handler="BtModificar" class="btn btn-warning btn-sm" asp-route-data="@elemento.Id" />
                                    <input type="submit" value="Borrar" asp-page-handler="BtBorrarVal" class="btn btn-danger btn-sm" asp-route-data="@elemento.Id" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </form>
    </div>
</center>